node_modules/

# NOTE: dist/ IS committed — GitHub Actions run the bundled dist/action.js
# directly from the repo tree, so it must be tracked. Source maps and scratch
# declaration files aren't needed at runtime and stay ignored.
*.js.map
*.d.ts.map
!dist/**/*.d.ts
!.prettierrc.js

npm-debug.log*
yarn-debug.log*
yarn-error.log*

.env
.env.local
.env.*.local

.DS_Store
.claude/
.vscode/
.idea/
*.swp
*.swo

coverage/
.nyc_output/
