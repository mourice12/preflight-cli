{
  "name": "preflight-ci",
  "version": "0.3.0",
  "description": "Validate GitHub Actions workflows against a repo's actual GitHub configuration before pushing.",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "preflight": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:action",
    "build:action": "esbuild src/action.ts --bundle --platform=node --target=node20 --outfile=dist/action.js --minify",
    "dev": "tsc --watch",
    "test": "node --import tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@anthropic-ai/sdk": "^0.90.0",
    "@octokit/rest": "^22.0.1",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
